---
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

interface Props {
	title?: string;
}
const { title = "Fernwood Coffee" } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
	</head>
	<body>
		<Navbar />

		<main>
			<slot />
		</main>

		<Footer />

		<style is:global>
			:root {
				--bg: #fbf6ee;
				--ink: #2c231b;
				--muted: #7a6b58;
				--accent: #a2472a;
				--accent-dark: #7c341d;
				--card: #ffffff;
				--border: #e8dcc8;
				font-family: "Helvetica Neue", Arial, sans-serif;
			}

			* {
				box-sizing: border-box;
			}

			body {
				margin: 0;
				background: var(--bg);
				color: var(--ink);
				line-height: 1.55;
			}

			main {
				max-width: 1100px;
				margin: 0 auto;
				padding: 0 2rem;
				min-height: 70vh;
			}

			h1 {
				font-size: 2.4rem;
				margin-bottom: 0.25rem;
			}

			h2 {
				font-size: 1.6rem;
			}

			.subtitle {
				color: var(--muted);
				margin-top: 0;
			}

			.btn {
				display: inline-block;
				background: var(--accent);
				color: #fff;
				padding: 0.7rem 1.4rem;
				border-radius: 6px;
				text-decoration: none;
				font-weight: 600;
			}

			.btn:hover {
				background: var(--accent-dark);
			}
		</style>
	</body>
</html>
