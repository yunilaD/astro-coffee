---
interface HourRow {
    day: string;
    hours: string;
}

const schedule: HourRow[] = [
    { day: "Monday – Friday", hours: "7:00 AM – 6:00 PM" },
    { day: "Saturday", hours: "8:00 AM – 6:00 PM" },
    { day: "Sunday", hours: "8:00 AM – 3:00 PM" },
];
---

<div class="hours">
    <h3>Opening Hours</h3>
    <table>
        <tbody>
            {
                schedule.map((row) => (
                    <tr>
                        <td>{row.day}</td>
                        <td>{row.hours}</td>
                    </tr>
                ))
            }
        </tbody>
    </table>
</div>

<style>
    .hours {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 1.5rem;
    }

    .hours h3 {
        margin: 0 0 1rem;
        font-size: 1.1rem;
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    td {
        padding: 0.5rem 0;
        border-top: 1px solid var(--border);
        font-size: 0.9rem;
    }

    tr:first-child td {
        border-top: none;
    }

    td:first-child {
        color: var(--muted);
    }

    td:last-child {
        text-align: right;
        font-weight: 600;
    }
</style>
