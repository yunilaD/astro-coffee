---
import Layout from "../layouts/Layout.astro";
import Testimonial from "../components/Testimonial.astro";

interface MenuItem {
  id: string;
  name: string;
  category: string;
  price: number;
  image: string;
  description: string;
}

const res = await fetch("http://localhost:3000/api/menu");
const menuData: MenuItem[] = await res.json();

import Likes from "../components/Like.tsx";

const featured = menuData.slice(0, 3);
---

<Layout title="Astro Coffee — Home">
  <section class="hero">
    <h1>Slow mornings start here.</h1>
    <p class="subtitle">
      Small-batch coffee, fresh pastries, and a quiet corner to sit in.
    </p>
    <a class="btn" href="/menu">View the menu</a>
  </section>

  <section class="featured">
    <h2>Featured this week</h2>
    <div class="grid">
      {
        featured.map((item) => (
          <div class="card">
            <img src={item.image} alt={item.name} />
            <div class="card-body">
              <h3>{item.name}</h3>
              <p class="desc">{item.description}</p>
              <p class="price">${item.price.toFixed(2)}</p>
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <section class="testimonials">
    <h2>What people say</h2>
    <div class="testimonial-grid">
      <Testimonial
        quote="The oat latte is what got me in the door. The quiet corner table is why I keep coming back."
        name="Ishara D."
        role="Regular"
      />
      <Testimonial
        quote="Best almond croissant in the neighborhood, hands down. Worth the walk."
        name="Marc T."
        role="Regular"
      />
      <Testimonial
        quote="Good coffee, better playlist. Never the same song twice."
        name="Anonymous review"
      />
    </div>
  </section>

  <section class="feedback-section">
    <div class="feedback-card">
      <h3>Show Some Love</h3>
      <Likes client:visible />
    </div>
  </section>

  <style>
    .hero {
      text-align: center;
      padding: 4rem 1rem 3rem;
    }

    .featured {
      padding-bottom: 3rem;
    }

    .testimonials {
      padding-bottom: 4rem;
    }

    .testimonial-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 1.5rem;
      margin-top: 1.5rem;
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 1.5rem;
      margin-top: 1.5rem;
    }

    .card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 10px;
      overflow: hidden;
    }

    .card img {
      width: 100%;
      height: 160px;
      object-fit: cover;
      display: block;
    }

    .card-body {
      padding: 1rem;
    }

    .card-body h3 {
      margin: 0 0 0.4rem;
      font-size: 1.1rem;
    }

    .desc {
      color: var(--muted);
      font-size: 0.9rem;
      margin: 0 0 0.6rem;
    }

    .price {
      font-weight: 700;
      color: var(--accent-dark);
      margin: 0;
    }

    .feedback-section {
      padding: 2rem 0 4rem;
      display: flex;
      justify-content: center;
    }

    .feedback-card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 2rem;
      text-align: center;
      max-width: 400px;
      width: 100%;
      box-shadow: 0 4px 12px rgba(44, 35, 27, 0.04);
      transition:
        transform 0.2s ease,
        box-shadow 0.2s ease;
    }

    .feedback-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 16px rgba(44, 35, 27, 0.08);
    }

    .feedback-card h3 {
      margin: 0 0 0.75rem;
      font-size: 1.25rem;
      color: var(--ink);
    }

    .feedback-card :global(.likes) {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.75rem;
    }

    .feedback-card :global(.likes p) {
      margin: 0;
      font-size: 0.95rem;
      color: var(--muted);
      font-weight: 500;
    }

    .feedback-card :global(.likes button) {
      background: var(--accent);
      color: white;
      border: none;
      padding: 0.6rem 1.8rem;
      border-radius: 20px;
      font-size: 0.95rem;
      font-weight: 600;
      cursor: pointer;
      transition:
        background-color 0.2s ease,
        transform 0.1s ease;
    }

    .feedback-card :global(.likes button:hover) {
      background: var(--accent-dark);
    }

    .feedback-card :global(.likes button:active) {
      transform: scale(0.96);
    }
  </style>
</Layout>
